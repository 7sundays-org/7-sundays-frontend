{
  "id": "testimonials",
  "type": "SharedSlice",
  "name": "Testimonials",
  "description": "Sezione testimonianze con carousel o griglia.",
  "variations": [
    {
      "id": "default",
      "name": "Carousel",
      "docURL": "...",
      "version": "initial",
      "description": "Carousel di testimonianze",
      "imageUrl": "",
      "primary": {
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Titolo (opzionale)",
            "placeholder": "",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em"
          }
        },
        "display_mode": {
          "type": "Select",
          "config": {
            "label": "Modalità",
            "options": ["carousel", "grid"],
            "default_value": "carousel"
          }
        },
        "testimonials": {
          "type": "Group",
          "config": {
            "label": "Testimonianze",
            "fields": {
              "author_name": {
                "type": "Text",
                "config": {
                  "label": "Nome autore",
                  "placeholder": "Es. Mario Rossi"
                }
              },
              "author_role": {
                "type": "Text",
                "config": {
                  "label": "Ruolo",
                  "placeholder": "Es. Ospite, Proprietario"
                }
              },
              "title": {
                "type": "Text",
                "config": {
                  "label": "Titolo recensione",
                  "placeholder": "Es. Soggiorno fantastico!"
                }
              },
              "quote": {
                "type": "StructuredText",
                "config": {
                  "label": "Testo",
                  "placeholder": "Testo della recensione",
                  "allowTargetBlank": true,
                  "multi": "paragraph,strong,em"
                }
              },
              "stars": {
                "type": "Number",
                "config": {
                  "label": "Stelle (1-5)",
                  "placeholder": "5"
                }
              },
              "source": {
                "type": "Select",
                "config": {
                  "label": "Piattaforma",
                  "options": ["airbnb", "booking", "google", "manuale"],
                  "default_value": "manuale"
                }
              },
              "reference_link": {
                "type": "Link",
                "config": {
                  "label": "Link originale",
                  "allowTargetBlank": true
                }
              }
            }
          }
        }
      }
    }
  ]
}
