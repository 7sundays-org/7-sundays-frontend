{
  "format": "custom",
  "id": "faq_item",
  "label": "FAQ Item",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": ""
        }
      },
      "question": {
        "type": "Text",
        "config": {
          "label": "Domanda",
          "placeholder": ""
        }
      },
      "answer": {
        "type": "StructuredText",
        "config": {
          "label": "Risposta",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item"
        }
      },
      "category": {
        "type": "Select",
        "config": {
          "label": "Categoria",
          "placeholder": "",
          "options": ["proprietario", "hosting", "generale"],
          "default_value": "generale"
        }
      }
    }
  }
}
